SUMMERDAY_DATA_DIR=data
SUMMERDAY_MEDIA_DIR=data/media
SUMMERDAY_TIMEZONE=America/Toronto

# Use fake for offline development; command requires {speed} or {wpm}.
SUMMERDAY_TTS_PROVIDER=fake
# Example: my-tts --rate {wpm} --output {output_path}
SUMMERDAY_TTS_COMMAND=
SUMMERDAY_TTS_MODEL=configured

# Piper is a local neural TTS option. Default voice: fr_FR-siwis-medium.
# Alternative male voice: fr_FR-tom-medium.
SUMMERDAY_PIPER_MODEL=data/piper/fr_FR-siwis-medium.onnx
# Tune these after listening to generated audio.
SUMMERDAY_PIPER_BASELINE_WPM=100
SUMMERDAY_PIPER_LENGTH_SCALE=1

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CONTENT_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=600
