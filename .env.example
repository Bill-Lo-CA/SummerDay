SOMEADAY_DATA_DIR=data
SOMEADAY_MEDIA_DIR=data/media
SOMEADAY_TIMEZONE=America/Toronto

# Use fake for offline development; command requires {speed} or {wpm}.
SOMEADAY_TTS_PROVIDER=fake
# Example: my-tts --rate {wpm} --output {output_path}
SOMEADAY_TTS_COMMAND=
SOMEADAY_TTS_MODEL=configured

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CONTENT_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=600
